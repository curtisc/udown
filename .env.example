# Required
DATABASE_URL="postgresql://user:password@host:5432/udown?sslmode=verify-full"  # Use Neon's pooled (-pooler) connection string for production
AUTH_SECRET="" # Generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Auth providers (at least one required — uncomment and fill in)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""
# AUTH_EMAIL_ENABLED="true"

# Optional
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="events@yourdomain.com"

# SMS notifications (not used in v1)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# Cron job security
# CRON_SECRET="" # Vercel Cron authorization secret

# File storage (Vercel Blob for org logo)
# BLOB_READ_WRITE_TOKEN="" # Vercel Blob token
